# ── Локальный запуск без Docker ──────────────────────────────────────────────
# cp .env.local .env  (из папки backend/)

ENVIRONMENT=development
SECRET_KEY=local-dev-secret-key-32-chars-min!!

# База данных — локальный PostgreSQL (из Docker)
DATABASE_URL=postgresql+asyncpg://autoreports:secret@localhost:5432/autoreports

# Redis — не нужен в dev (используем eager mode)
REDIS_URL=redis://:redispass@localhost:6379/0

# Хранилище — LOCAL (файлы сохраняются в ./storage/)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# MinIO — не нужен при local storage
MINIO_ENDPOINT=localhost:19100
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# LLM — Ollama локально
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b

# Celery — синхронный режим (без Redis, задачи выполняются в том же процессе)
CELERY_TASK_ALWAYS_EAGER=true
